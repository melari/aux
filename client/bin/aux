#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cmd_help() {
  echo "Usage: aux <command>"
  echo ""
  echo "Commands:"
  echo "    aux sync <path>            -  Sync a linked directory with its remote git repository"
  echo "    aux sync-all               -  Sync all linked directories"
  echo "    aux init                   -  Install (or check) the background sync service"
  echo "    aux deinit                 -  Remove the background sync service"
  echo "    aux link <path> <git-url>  -  Save a path+url pair to your links"
  echo "    aux unlink <path>          -  Remove a link by path"
  echo "    aux status (alias: st)     -  List all links and their sync status"
  echo "    aux help                   -  Show this help message"
  echo ""
}

case "$1" in
help) cmd_help ;;
sync) exec "$SCRIPT_DIR/commands/sync" "$2" ;;
sync-all) exec "$SCRIPT_DIR/commands/sync-all" ;;
init) exec "$SCRIPT_DIR/commands/init" ;;
deinit) exec "$SCRIPT_DIR/commands/deinit" ;;
link) exec "$SCRIPT_DIR/commands/link" "$2" "$3" ;;
unlink) exec "$SCRIPT_DIR/commands/unlink" "$2" ;;
status | st) exec "$SCRIPT_DIR/commands/status" ;;
*)
  echo "Unknown command: $1"
  echo "Run 'aux help' for usage instructions."
  exit 1
  ;;
esac
